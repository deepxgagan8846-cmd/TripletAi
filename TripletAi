LANGUAGE RULE: {lang}"""

def get_lang(val):
    if val=="auto": return "Detect user language and reply in SAME language automatically."
    return f"ALWAYS reply in {val}."

def save_history(history):
    try:
        all_h = {}
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE,"r",encoding="utf-8") as f: all_h=json.load(f)
        key = datetime.now().strftime("%Y-%m-%d %H:%M")
        safe = []
        for m in history:
            if isinstance(m,dict):
                c = m.get("content","")
                if isinstance(c,list): c=" ".join(p.get("text","") for p in c if isinstance(p,dict) and p.get("type")=="text") or "[Image]"
                safe.append({"role":m.get("role",""),"content":str(c)})
        all_h[key]=safe
        with open(HISTORY_FILE,"w",encoding="utf-8") as f: json.dump(all_h,f,ensure_ascii=False,indent=2)
    except: pass

def load_sessions():
    try:
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE,"r",encoding="utf-8") as f: return list(json.load(f).keys())
    except: pass
    return []

def load_session(name):
    try:
        if os.path.exists(HISTORY_FILE):
            with open(HISTORY_FILE,"r",encoding="utf-8") as f: return json.load(f).get(name,[])
    except: pass
    return []

def encode_img(path):
    try:
        with open(path,"rb") as f: return base64.b64encode(f.read()).decode()
    except: return None

def get_welcome():
    return [{"role":"assistant","content":"👋 **Hello! How are you?**\n\nI am **TripletAI**, your personal AI assistant created by **Gagandeep Singh**! 🔺\n\nI can help you with:\n- 🌌 Universe, Galaxies & Space\n- 🔢 Mathematics & Science\n- 💻 Coding in any language\n- 🌍 History, Geography & more\n- 📷 Image analysis\n- 🎤 Voice questions\n\n**How can I help you today?**"}]

def chat(message, history, language, image):
    if not message.strip() and image is None:
        yield history, "", None
        return

    if not API_KEY:
        h = (history or get_welcome()) + [
            {"role":"user","content": message or "📷 Image"},
            {"role":"assistant","content":"⚠️ **API Key nahi mili!**\n\nPowerShell:\n```\n$env:GROQ_API_KEY=\"gsk_key\"\npython app_1.py\n```"}
        ]
        yield h,"",None
        return

    lang_val = LANGUAGES.get(language,"auto")
    sys_text = SYSTEM.format(lang=get_lang(lang_val))
    api_msgs = [{"role":"system","content":sys_text}]

    for m in (history or []):
        if isinstance(m,dict) and m.get("role") in ("user","assistant"):
            c=m.get("content","")
            if isinstance(c,list): c=" ".join(p.get("text","") for p in c if isinstance(p,dict) and p.get("type")=="text")
            if c: api_msgs.append({"role":m["role"],"content":str(c)})

    if image:
        b64=encode_img(image)
        if b64:
            user_content=[{"type":"text","text":message or "Describe this image."},{"type":"image_url","image_url":{"url":f"data:image/jpeg;base64,{b64}"}}]
            display=f"📷 {message}" if message else "📷 Image Analysis"
        else:
            user_content=message; display=message
    else:
        user_content=message; display=message

    api_msgs.append({"role":"user","content":user_content})
    new_h=(history or get_welcome())+[{"role":"user","content":display},{"role":"assistant","content":""}]

    try:
        mdl="llama-3.2-11b-vision-preview" if image else "llama-3.3-70b-versatile"
        stream=client.chat.completions.create(model=mdl,messages=api_msgs,stream=True,max_tokens=2048,temperature=0.7)
        partial=""
        for chunk in stream:
            delta=chunk.choices[0].delta.content or ""
            partial+=delta
            new_h[-1]={"role":"assistant","content":partial}
            yield new_h,"",None
        save_history(new_h)
    except Exception as e:
        new_h[-1]={"role":"assistant","content":f"❌ Error: {str(e)}"}
        yield new_h,"",None

def clear_chat(): return get_welcome(),"",None
def del_all():
    try:
        if os.path.exists(HISTORY_FILE): os.remove(HISTORY_FILE)
    except: pass
    return get_welcome(),"",None,gr.Dropdown(choices=[],value=None)
def refresh_s():
    s=load_sessions()
    return gr.Dropdown(choices=s,value=s[-1] if s else None)
def load_sel(name): return load_session(name) if name else get_welcome()

